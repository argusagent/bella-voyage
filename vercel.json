{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/trip",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/welcome",
      "destination": "/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/bella-voyage-qr.(svg|png)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        },
        {
          "key": "Content-Disposition",
          "value": "inline"
        }
      ]
    }
  ]
}
